# Database Connection URL
# SQLite default: sqlite:///backend/data/ahal_backend.db
# PostgreSQL: postgresql://username:password@host:port/database_name
AHAL_DATABASE_URL=postgresql://ahal:ahalpass@localhost:5432/ahal_db

# GitHub Webhook HMAC signature key (mandatory for signature validation)
AHAL_GITHUB_WEBHOOK_SECRET=change-me-in-production

# GitHub API Personal Access Token (optional, used to authenticate PR comments and files retrieval)
AHAL_GITHUB_TOKEN=

# Prediction Surfacing (alert fatigue management)
AHAL_GITHUB_COMMENT_MIN_CALIBRATED_SCORE=0.5
AHAL_GITHUB_COMMENT_MAX_PREDICTIONS=5

# Indexing Pipeline Tuning
AHAL_MAX_COMMITS_TO_INDEX=2000
AHAL_MAX_FILES_PER_COMMIT=50
AHAL_INDEX_WORKER_THREADS=2
